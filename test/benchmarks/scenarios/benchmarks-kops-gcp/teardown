# teardown: phase 3 of the modular kOps/GCE benchmark flow.
# Deletes a cluster created by create-cluster and releases associated resources.
# Designed to be safe to run even if create-cluster failed part way through.

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

usage() {
  cat <<EOF
Usage: teardown --cluster-name NAME [flags]

Delete a kOps cluster created by create-cluster.

Flags:
  --cluster-name NAME   Cluster to delete (required)
  --cleanup-bucket      Also delete the kOps state-store bucket (default: keep it)
  --keep-boskos         Do not run 'resourcectl cleanup' (default: clean up when \$BOSKOS_HOST set)
  -h, --help            Show this help
EOF
}

CLUSTER_NAME=""
CLEANUP_BUCKET="false"
KEEP_BOSKOS="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --cluster-name) CLUSTER_NAME="$2"; shift 2 ;;
    --cleanup-bucket) CLEANUP_BUCKET="true"; shift ;;
    --keep-boskos) KEEP_BOSKOS="true"; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown flag: $1 (try --help)" ;;
  esac
done

[[ -n "${CLUSTER_NAME}" ]] || die "--cluster-name is required (try --help)"

cd "${REPO_ROOT}"

install_tools

STATE_DIR="$(state_dir "${CLUSTER_NAME}")"

# Prefer the recorded state (KOPS_STATE_STORE etc.); if create-cluster failed
# before writing it, reconstruct enough to still delete the cluster.
if [[ -f "${STATE_DIR}/cluster.env" ]]; then
  # shellcheck disable=SC1091
  source "${STATE_DIR}/cluster.env"
  export KOPS_STATE_STORE
else
  log "No cluster.env for '${CLUSTER_NAME}'; reconstructing state store to attempt deletion."
  resolve_project
  ensure_state_store
fi

log "Deleting cluster ${CLUSTER_NAME}..."
kops delete cluster --name "${CLUSTER_NAME}" --yes || \
  log "kops delete cluster failed or cluster already gone; continuing cleanup."

if [[ "${CLEANUP_BUCKET}" == "true" && -n "${KOPS_STATE_STORE:-}" ]]; then
  log "Deleting state-store bucket ${KOPS_STATE_STORE}..."
  gcloud storage buckets delete "${KOPS_STATE_STORE}" --quiet || \
    log "Bucket deletion failed; continuing."
fi

if [[ -n "${BOSKOS_HOST:-}" && "${KEEP_BOSKOS}" != "true" ]]; then
  log "Releasing Boskos resources..."
  resourcectl cleanup || log "resourcectl cleanup failed; continuing."
fi

if [[ -d "${STATE_DIR}" ]]; then
  log "Removing local state at ${STATE_DIR}..."
  rm -rf "${STATE_DIR}"
fi

log "Teardown of '${CLUSTER_NAME}' complete."
