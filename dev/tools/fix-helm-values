"""Generates helm/templates/_controller-args.generated.tpl and updates the
controller: section of helm/values.yaml from flag definitions in main.go."""

import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
MAIN_GO = REPO_ROOT / "cmd" / "agent-sandbox-controller" / "main.go"
VALUES_YAML = REPO_ROOT / "helm" / "values.yaml"
ARGS_TPL = REPO_ROOT / "helm" / "templates" / "_controller-args.generated.tpl"

# Flags excluded from generation — handled elsewhere in the chart.
SKIP_FLAGS = {
    "metrics-bind-address",       # fixed port, wired in deployment ports
    "health-probe-bind-address",  # fixed port, wired in deployment ports
    "extensions",                 # controlled by extensions.enabled
}


def to_camel_case(name: str) -> str:
    parts = name.split("-")
    return parts[0] + "".join(p.capitalize() for p in parts[1:])


def parse_flags(source):
    pattern = re.compile(
        r'flag\.(Bool|Int|Float64|String)Var\s*\(\s*&\w+\s*,\s*"([^"]+)"\s*,\s*([^,\n]+?)\s*,'
    )
    flags = []
    for m in pattern.finditer(source):
        typ, name, default = m.group(1), m.group(2), m.group(3).strip()
        if name in SKIP_FLAGS:
            continue
        flags.append({"type": typ, "name": name, "key": to_camel_case(name), "default": default})
    return flags


def yaml_default(f):
    typ, default = f["type"], f["default"]
    if typ == "String":
        val = default.strip('"')
        return f'"{val}"'
    return default  # Bool/Int/Float64 literals are valid YAML as-is


def generate_controller_section(flags):
    lines = ["controller:"]
    for f in flags:
        lines.append(f"  {f['key']}: {yaml_default(f)}")
    lines.append(
        "  # extraArgs passes additional flags not listed above (e.g. zap logging flags)."
    )
    lines.append("  extraArgs: []")
    return "\n".join(lines)


def generate_args_tpl(flags):
    lines = ['{{- define "agent-sandbox.controllerArgs" -}}']

    # leader-elect is always first
    for f in flags:
        if f["name"] == "leader-elect":
            lines.append(f"- --leader-elect={{{{ .Values.controller.{f['key']} }}}}")
            break

    # extensions is second (special-cased: controls RBAC too, not just a flag)
    lines += [
        "{{- if .Values.extensions.enabled }}",
        "- --extensions",
        "{{- end }}",
    ]

    # All other flags in main.go order
    for f in flags:
        name, key, typ, default = f["name"], f["key"], f["type"], f["default"]
        if name == "leader-elect":
            continue
        # Optional string flags: only emit when non-empty
        if typ == "String" and default.strip('"') == "":
            lines.append(f"{{{{- if .Values.controller.{key} }}}}")
            lines.append(f"- --{name}={{{{ .Values.controller.{key} }}}}")
            lines.append("{{- end }}")
        else:
            lines.append(f"- --{name}={{{{ .Values.controller.{key} }}}}")

    lines += [
        "{{- range .Values.controller.extraArgs }}",
        "- {{ . | quote }}",
        "{{- end }}",
        "{{- end }}",
    ]
    return "\n".join(lines)


def update_values_yaml(new_controller_section):
    text = VALUES_YAML.read_text()
    # Replace controller: block — lines indented or blank until next top-level key
    updated = re.sub(
        r"^controller:\n(?:[ \t#][^\n]*\n|\n)*",
        new_controller_section + "\n\n",
        text,
        flags=re.MULTILINE,
    )
    if updated == text:
        print(f"  {VALUES_YAML.name}: no changes")
    else:
        VALUES_YAML.write_text(updated)
        print(f"  Updated {VALUES_YAML.relative_to(REPO_ROOT)}")


def main():
    source = MAIN_GO.read_text()
    flags = parse_flags(source)

    if not flags:
        print("ERROR: no flags found in main.go", file=sys.stderr)
        sys.exit(1)

    print(f"Parsed {len(flags)} flags from {MAIN_GO.relative_to(REPO_ROOT)}")

    controller_section = generate_controller_section(flags)
    args_tpl_content = generate_args_tpl(flags) + "\n"

    update_values_yaml(controller_section)

    existing = ARGS_TPL.read_text() if ARGS_TPL.exists() else ""
    if args_tpl_content != existing:
        ARGS_TPL.write_text(args_tpl_content)
        print(f"  Generated {ARGS_TPL.relative_to(REPO_ROOT)}")
    else:
        print(f"  {ARGS_TPL.name}: no changes")


if __name__ == "__main__":
    main()
