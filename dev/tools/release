import os
import argparse
import subprocess
import sys

def run_command(cmd):
    """Helper to run shell commands."""
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError:
        print(f"Error running command: {' '.join(cmd)}")
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description='Package the Helm chart for release.')
    parser.add_argument('--tag', required=True, help='The git tag for the release.')
    parser.add_argument('--publish', action='store_true', help='Publish the release to GitHub.')
    args = parser.parse_args()
    tag = args.tag

    # Create the release_assets directory if it doesn't exist
    if not os.path.exists('release_assets'):
        os.makedirs('release_assets')

    # --- Package Helm chart ---
    print(f'INFO: Packaging Helm chart with appVersion {tag}')
    run_command([
        'helm', 'package', './helm',
        '--app-version', tag,
        '--version', tag,
        '--destination', 'release_assets',
    ])
    chart_package = f'release_assets/agent-sandbox-{tag}.tgz'
    if not os.path.exists(chart_package):
        print(f"❌ Expected chart package not found: {chart_package}")
        sys.exit(1)
    print(f'INFO: Successfully created {chart_package}')

    # --- Publish Draft Release ---
    if args.publish:
        print(f"INFO: Publishing draft release {tag} to GitHub...")
        cmd = [
            "gh", "release", "create", tag,
            chart_package,
            "--generate-notes",
            "--title", tag,
            "--verify-tag",
            "--draft",
            "--repo", "kubernetes-sigs/agent-sandbox"
        ]
        run_command(cmd)
        print(f"🎉 Draft release {tag} published successfully!")
        print(f"👉 Go to https://github.com/kubernetes-sigs/agent-sandbox/releases to review and publish.")

if __name__ == '__main__':
    main()
