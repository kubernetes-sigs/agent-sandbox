"""Runs bump-chart-version after all other fix-* generators have completed.

This script is intentionally named fix-zz-* so it sorts last in the
fix-* execution order used by dev/ci/presubmits/test-autogen-up-to-date.
"""

import os
import subprocess

script_dir = os.path.dirname(os.path.realpath(__file__))
repo_root = os.path.abspath(os.path.join(script_dir, '..', '..'))

subprocess.check_call([os.path.join(script_dir, "bump-chart-version")], cwd=repo_root)
