import argparse
import glob
import json
import os
import re
import subprocess
import sys


def run_command(cmd):
    """Helper to run shell commands."""
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError:
        print(f"Error running command: {' '.join(cmd)}")
        sys.exit(1)


def get_release_info(tag):
    """Returns (exists, is_draft) for the GitHub release."""
    cmd = [
        "gh", "release", "view", tag,
        "--repo", "kubernetes-sigs/agent-sandbox",
        "--json", "isDraft",
    ]

    try:
        result = subprocess.run(
            cmd,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except FileNotFoundError:
        print("Error: GitHub CLI 'gh' was not found in PATH.")
        sys.exit(1)

    if result.returncode == 0:
        try:
            release_info = json.loads(result.stdout or "{}")
        except json.JSONDecodeError:
            print(
                "Error parsing GitHub release info for "
                f"{tag}: {' '.join(cmd)} returned invalid JSON."
            )
            stdout = (result.stdout or "").strip()
            if stdout:
                print(stdout)
            sys.exit(1)

        return True, bool(release_info.get("isDraft"))

    stderr = (result.stderr or "").strip()
    stdout = (result.stdout or "").strip()
    combined_output = "\n".join(part for part in [stderr, stdout] if part)
    normalized_output = combined_output.lower()
    if "release not found" in normalized_output or "http 404" in normalized_output:
        return False, False

    print(
        "Error checking GitHub release info for "
        f"{tag}: {' '.join(cmd)} failed with exit code {result.returncode}."
    )
    if combined_output:
        print(combined_output)
    sys.exit(1)


def _kustomization_resource_paths(path):
    """Resource file paths listed under `resources:` in a kustomization file.

    Deliberately stdlib-only (the release tool has no third-party deps): this
    parses the simple `resources:` list this repo uses rather than pulling in
    PyYAML.
    """
    paths = set()
    in_resources = False
    with open(path) as f:
        for raw in f:
            stripped = raw.strip()
            if not stripped or stripped.startswith("#"):
                continue
            if not raw[:1].isspace():
                # A top-level key ends the resources block unless this *is* it.
                in_resources = stripped == "resources:"
                continue
            if in_resources and stripped.startswith("- "):
                paths.add(stripped[2:].strip())
    return paths


def check_install_manifest_drift(all_yaml_files):
    """Fail loudly if k8s/kustomization.yaml drifts from the flat release assets.

    manifest.yaml/extensions.yaml are concatenated from every k8s/**/*.yaml
    (except kustomization.yaml); install.yaml is rendered from
    kustomization.yaml, whose `resources:` list is hand-maintained. Both assemble
    whole files, so they stay in sync iff kustomization.yaml lists exactly those
    globbed files -- minus extensions.controller.yaml, the intentionally-excluded
    duplicate controller Deployment (the core controller.yaml is patched
    instead). Without this guard, a new file dropped into k8s/ would land in the
    flat assets automatically yet be silently missing from install.yaml.
    """
    globbed = {os.path.relpath(f, "k8s") for f in all_yaml_files}
    globbed.discard("extensions.controller.yaml")
    listed = _kustomization_resource_paths("k8s/kustomization.yaml")

    missing = globbed - listed
    extra = listed - globbed
    if missing or extra:
        print("❌ k8s/kustomization.yaml has drifted from the flat release assets:")
        for f in sorted(missing):
            print(f"   - {f}: in manifest/extensions.yaml but not listed in kustomization.yaml")
        for f in sorted(extra):
            print(f"   - {f}: listed in kustomization.yaml but not a k8s asset file")
        print("   Update k8s/kustomization.yaml so install.yaml stays in sync.")
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(description="Generate release manifests.")
    parser.add_argument("--tag", required=True, help="The git tag for the release.")
    parser.add_argument("--publish", action="store_true", help="Publish the release to GitHub.")
    parser.add_argument(
        "--model",
        default=os.getenv("GEMINI_MODEL", "gemini-2.5-flash"),
        help="Gemini model to use for generating release notes.",
    )
    args = parser.parse_args()
    tag = args.tag

    # Create the release_assets directory if it doesn't exist.
    if not os.path.exists("release_assets"):
        os.makedirs("release_assets")

    # kustomization.yaml files describe how to assemble the manifests (see the
    # all-in-one install.yaml below); they are not themselves resources, so they
    # must not be concatenated into the flat manifest/extensions assets.
    all_yaml_files = [
        f
        for f in glob.glob("k8s/**/*.yaml", recursive=True)
        if os.path.basename(f) != "kustomization.yaml"
    ]
    image_url = f"registry.k8s.io/agent-sandbox/agent-sandbox-controller:{args.tag}"

    def replace_image(text):
        """Replace the ko:// image placeholder with the published controller image."""
        return re.sub(
            r"ko://sigs.k8s.io/agent-sandbox/cmd/agent-sandbox-controller.*",
            image_url,
            text,
        )

    # --- Generate manifest.yaml ---
    print("INFO: Preparing core manifest.yaml")
    manifest_files = [f for f in all_yaml_files if "extensions" not in os.path.basename(f)]
    with open("release_assets/manifest.yaml", "w") as outfile:
        for fname in sorted(manifest_files):
            with open(fname) as infile:
                outfile.write(infile.read())
                outfile.write("---\n")

    # Replace image placeholder in manifest.yaml.
    print(f"INFO: Replacing image placeholder in core manifest.yaml with: {image_url}")
    with open("release_assets/manifest.yaml", "r") as file:
        filedata = file.read()

    filedata = replace_image(filedata)

    with open("release_assets/manifest.yaml", "w") as file:
        file.write(filedata)
    print("INFO: Successfully created release_assets/manifest.yaml")

    # --- Generate extensions.yaml ---
    print("INFO: Preparing extensions.yaml")
    extension_files = [f for f in all_yaml_files if "extensions" in os.path.basename(f)]
    with open("release_assets/extensions.yaml", "w") as outfile:
        for fname in sorted(extension_files):
            with open(fname) as infile:
                outfile.write(infile.read())
                outfile.write("---\n")

    # Replace image placeholder in extensions.yaml.
    print(f"INFO: Replacing image placeholder in extensions.yaml with: {image_url}")
    with open("release_assets/extensions.yaml", "r") as file:
        filedata = file.read()

    filedata = replace_image(filedata)

    with open("release_assets/extensions.yaml", "w") as file:
        file.write(filedata)
    print("INFO: Successfully created release_assets/extensions.yaml")

    # --- Generate install.yaml (all-in-one, kustomize/GitOps friendly) ---
    # manifest.yaml + extensions.yaml both declare the controller Deployment and
    # are meant for sequential `kubectl apply -f` (last-write-wins). That duplicate
    # resource id is rejected by kustomize/Config Sync/Argo CD, so we also publish a
    # single collision-free asset rendered from k8s/kustomization.yaml.
    #
    # Guard first: kustomization.yaml's resource list is hand-maintained, so make
    # sure it hasn't drifted from the glob the flat assets are built from.
    check_install_manifest_drift(all_yaml_files)

    print("INFO: Preparing all-in-one install.yaml")
    try:
        result = subprocess.run(
            ["kubectl", "kustomize", "k8s"],
            check=True,
            capture_output=True,
            text=True,
        )
    except FileNotFoundError:
        print("Error: 'kubectl' was not found in PATH; cannot render install.yaml.")
        sys.exit(1)
    except subprocess.CalledProcessError as e:
        print("Error: 'kubectl kustomize k8s' failed while rendering install.yaml.")
        for stream in (e.stderr, e.stdout):
            if stream and stream.strip():
                print(stream.strip())
        sys.exit(1)

    print(f"INFO: Replacing image placeholder in install.yaml with: {image_url}")
    with open("release_assets/install.yaml", "w") as file:
        file.write(replace_image(result.stdout))
    print("INFO: Successfully created release_assets/install.yaml")

    # --- Publish Draft Release ---
    if args.publish:
        print(f"INFO: Publishing draft release {tag} to GitHub...")
        manifest_path = "release_assets/manifest.yaml"
        extensions_path = "release_assets/extensions.yaml"
        install_path = "release_assets/install.yaml"

        if not all(
            os.path.exists(p) for p in (manifest_path, extensions_path, install_path)
        ):
            print("❌ Release assets missing. Cannot publish.")
            sys.exit(1)

        release_exists, is_draft = get_release_info(tag)

        if release_exists:
            if not is_draft:
                print(
                    f"❌ Release {tag} already exists and is published. "
                    "Refusing to update assets."
                )
                sys.exit(1)

            print(f"INFO: Draft release {tag} already exists; updating assets...")
            run_command([
                "gh", "release", "upload", tag,
                manifest_path,
                extensions_path,
                install_path,
                "--clobber",
                "--repo", "kubernetes-sigs/agent-sandbox",
            ])
        else:
            # Generate release notes using the external standalone script.
            notes_file = "release_assets/release_notes.md"
            print("INFO: Generating release notes using dev/tools/generate-release-notes...")
            try:
                subprocess.run(
                    [
                        "./dev/tools/generate-release-notes",
                        "--tag", tag,
                        "--output", notes_file,
                        "--model", args.model,
                    ],
                    check=True,
                )
                print(f"INFO: Release notes generated at {notes_file}")
            except subprocess.CalledProcessError as e:
                print(f"⚠️ Error generating release notes with script: {e}")
                print("⚠️ Falling back to default GitHub notes on release creation.")
                notes_file = None

            cmd = [
                "gh", "release", "create", tag,
                manifest_path,
                extensions_path,
                install_path,
            ]

            if notes_file:
                cmd.extend(["--notes-file", notes_file])

            cmd.extend([
                "--generate-notes",
                "--title", tag,
                "--verify-tag",
                "--draft",
                "--repo", "kubernetes-sigs/agent-sandbox",
            ])

            run_command(cmd)

        print(f"🎉 Draft release {tag} published successfully!")
        print("👉 Go to https://github.com/kubernetes-sigs/agent-sandbox/releases to review and publish.")


if __name__ == "__main__":
    main()