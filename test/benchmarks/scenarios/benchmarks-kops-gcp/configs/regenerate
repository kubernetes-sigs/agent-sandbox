#
# regenerate: re-author the config manifests with kOps itself.
#
# Rather than hand-maintaining kOps YAML, each configs/*.yaml is the output of
# `kops create cluster --dry-run -o yaml` (so kOps owns the spec defaults),
# with a few documented post-processing edits:
#   * project           -> PLACEHOLDER_PROJECT (create-cluster substitutes the
#                          resolved project before `kops create -f`)
#   * configBase        -> removed (derived from KOPS_STATE_STORE at create time)
#   * kubernetesVersion -> removed (resolved from the stable channel at create
#                          time, matching the old CLI-flags behavior)
#   * instance group image -> removed (defaulted by kOps at create time)
#   * creationTimestamp -> removed (dry-run fixture noise)
#
# Run this after bumping KOPS_VERSION in ../lib.sh, then review the diff.
# Requires the pinned kops on PATH (see ../lib.sh); no GCP access is needed —
# --dry-run with a memfs state store is fully offline.

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

ZONE="us-central1-a"

generate() {
  local name="$1" cp_size="$2" node_count="$3" node_size="$4" out="$5" desc="$6"

  kops create cluster \
    --cloud=gce \
    --gce-service-account=default \
    --name="${name}" \
    --zones="${ZONE}" \
    --project=PLACEHOLDER_PROJECT \
    --dns=none \
    --control-plane-count=1 \
    --control-plane-size="${cp_size}" \
    --node-count="${node_count}" \
    --node-size="${node_size}" \
    --state memfs://configs-regenerate \
    --dry-run \
    -o yaml \
  | sed \
      -e '/^  creationTimestamp:/d' \
      -e '/^  configBase:/d' \
      -e '/^  kubernetesVersion:/d' \
      -e '/^  image: /d' \
      -e 's|^  project: PLACEHOLDER_PROJECT$|  project: PLACEHOLDER_PROJECT # replaced by create-cluster before `kops create -f`|' \
  > "${out}.tmp"

  {
    cat <<EOF
# ${desc}
#
# GENERATED by configs/regenerate using \`kops create cluster --dry-run -o yaml\`
# (see that script for the exact flags and post-processing edits). Do not
# hand-tune spec defaults here — regenerate instead, then review the diff.
#
# WARNING: kubernetesApiAccess and sshAccess below are the kOps defaults and
# expose the API server and SSH to the entire internet (0.0.0.0/0, ::/0).
# That is an accepted trade-off for short-lived benchmark clusters in
# disposable CI projects; do NOT reuse this manifest for anything long-lived
# without restricting those CIDRs.
EOF
    cat "${out}.tmp"
  } > "${out}"
  rm -f "${out}.tmp"
  echo "wrote ${out}"
}

#        name                        cp-size         nodes node-size       output
generate sandbox-benchmark-default   n2-standard-8   3     n2-standard-8   "${SCRIPT_DIR}/default.yaml" \
  "Default benchmark cluster shape: matches the original monolithic run script (1 control-plane + 3 nodes, all n2-standard-8)."
generate sandbox-benchmark-small     n2-standard-4   2     n2-standard-4   "${SCRIPT_DIR}/small.yaml" \
  "Small / cheap cluster for iterating on the harness itself; not for meaningful throughput numbers."
generate sandbox-benchmark-large     n2-standard-16  10    n2-standard-16  "${SCRIPT_DIR}/large.yaml" \
  "Large cluster for higher-scale stress runs; costs materially more per hour than the default preset."
