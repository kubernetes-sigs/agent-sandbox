import argparse
import os
import subprocess
import sys
import tempfile

from shared import utils


def _get_version_build_args():
    """Returns build args for version info injection into Go binaries."""
    import datetime
    git_version = utils.git_describe()
    git_sha = utils.git_sha()
    build_date = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    return [
        f"--build-arg=GIT_VERSION={git_version}",
        f"--build-arg=GIT_SHA={git_sha}",
        f"--build-arg=BUILD_DATE={build_date}",
    ]


def create_buildx_builder_if_not_exists(container_engine):
    if container_engine == "podman":
        print("podman detected, skipping buildx builder setup.")
        return
    builder_name = "agent-sandbox-builder"
    try:
        subprocess.run(
            ["docker", "buildx", "inspect", builder_name],
            check=True,
            capture_output=True,
            text=True,
        )
        print(f"buildx builder '{builder_name}' already exists.")
    except subprocess.CalledProcessError:
        print(f"creating buildx builder '{builder_name}'.")
        subprocess.run(
            ["docker", "buildx", "create", "--name", builder_name], check=True
        )
    subprocess.run(["docker", "buildx", "use", builder_name], check=True)


def build_image_with_podman(args, service_name, srcdir, dockerfile_path, image_tag):
    """Build an image using podman directly (equivalent to docker buildx build --output=type=docker)."""
    image_name = utils.get_full_image_name(args, service_name, tag=image_tag)
    build_cmd = [
        "podman",
        "build",
        "--progress=plain",
        "-t", image_name,
    ]
    for tag in args.extra_image_tags:
        extra_tag = utils.get_full_image_name(args, service_name, tag=tag)
        build_cmd.extend(["-t", extra_tag])

    dockerfile_rel = os.path.relpath(dockerfile_path, start=srcdir)
    build_cmd.extend(["-f", dockerfile_rel, "."])
    # Inject version info into Go binaries
    build_cmd.extend(_get_version_build_args())
    subprocess.run(build_cmd, cwd=srcdir, check=True)
    print(f"built image {image_name}")


def build_and_push_image_with_docker_buildx(args, service_name, srcdir, dockerfile_path, image_tag):
    platforms = "linux/amd64,linux/arm64"
    build_cmd = [
        "docker",
        "buildx",
        "build",
        "--progress=plain",
        f"--output=type={args.docker_build_output_type}",
    ]
    if args.docker_build_output_type == "registry":
        cache_ref = utils.get_full_image_name(args, service_name, tag="buildcache")
        build_cmd.extend([
            f"--cache-from=type=registry,ref={cache_ref}",
            f"--cache-to=type=registry,ref={cache_ref},mode=max",
        ])
        build_cmd.append("--platform=" + platforms)
    image_name = utils.get_full_image_name(args, service_name, tag=image_tag)
    build_cmd.extend(["-t", image_name])
    for tag in args.extra_image_tags:  # additional image tags
        extra_tag = utils.get_full_image_name(args, service_name, tag=tag)
        build_cmd.extend(["-t", extra_tag])
    build_cmd.extend([
        "-f",
        # Resolve the Dockerfile relative to the build context (the command
        # runs with cwd=srcdir): when a per-Dockerfile override sets the
        # context to another directory (sandbox-router-go uses the repo
        # root), the basename would silently pick that directory's
        # Dockerfile instead.
        os.path.relpath(dockerfile_path, srcdir),
        ".",
    ])
    # Inject version info into Go binaries
    build_cmd.extend(_get_version_build_args())
    subprocess.run(build_cmd, cwd=srcdir, check=True)
    print(f"pushed image {image_name}")


def load_kind_image(args, cluster_name, service_name, srcdir, image_tag):
    image_name = utils.get_full_image_name(args, service_name, tag=image_tag)

    kind_env = utils.kind_env(args.container_engine)

    if args.container_engine == "podman":
        # podman save to a temp tar, then kind load image-archive from it
        # (kind load image-archive does not support reading from stdin).
        with tempfile.NamedTemporaryFile(suffix=".tar", delete=False) as tmp:
            tmp_path = tmp.name
        try:
            subprocess.run(
                ["podman", "save", "--output", tmp_path, image_name],
                cwd=srcdir, check=True,
            )
            subprocess.run(
                ["kind", "load", "image-archive", f"--name={cluster_name}", tmp_path],
                cwd=srcdir, env=kind_env, check=True,
            )
        finally:
            os.unlink(tmp_path)
    else:
        subprocess.run(
            ["kind", "load", "docker-image", f"--name={cluster_name}", image_name],
            cwd=srcdir,
            env=kind_env,
            check=True,
        )
    print(f"loaded image {image_name} into kind cluster {args.kind_cluster_name}")


def build_and_push_image(args, service_name, srcdir, dockerfile_path, image_tag):
    if args.container_engine == "podman":
        build_image_with_podman(args, service_name, srcdir, dockerfile_path, image_tag)
    else:
        build_and_push_image_with_docker_buildx(args, service_name, srcdir, dockerfile_path, image_tag)
    if args.kind_cluster_name:
        load_kind_image(args, args.kind_cluster_name, service_name, srcdir, image_tag)


def main(args):
    """Builds and pushes all discovered Docker images."""
    if args.container_engine == "podman" and not args.kind_cluster_name:
        sys.exit("ERROR: --container-engine=podman requires --kind-cluster-name "
                 "(podman push to registry is not yet supported; use docker for registry pushes)")
    image_tag = args.image_tag or utils.get_image_tag()
    excluded_dirs = {"bin", "dev", "docs", "k8s", "site",
                     "temp", "tests", "tmp", ".venv"}

    if args.controller_only:
        # TODO: Implement an explicit inclusion strategy for controller only Dockerfile.
        excluded_dirs.update({"examples", "clients"})

    built = set()
    for root, dirs, files in os.walk(".", topdown=True):
        dirs[:] = [d for d in dirs if d not in excluded_dirs]

        if "Dockerfile" in files:
            dockerfile_path = os.path.join(root, "Dockerfile")
            context_dir = root
            service_name = os.path.basename(root)  # same as image name

            if not service_name:
                continue

            if service_name == ".":
                # The Dockerfile at the repo root is the controller image.
                # Single source of truth: do not copy it elsewhere.
                service_name = "agent-sandbox-controller"

            # Per-Dockerfile overrides. The Go sandbox-router needs the repo
            # root as build context (it imports the shared Go module) and
            # uses a "-go" suffix to avoid colliding with the Python router
            # image which still lives at clients/python/.../sandbox-router/.
            go_router_dir = os.path.join(".", "sandbox-router")
            if root == go_router_dir:
                context_dir = "."
                service_name = "sandbox-router-go"

            if args.images and service_name not in args.images:
                continue

            if service_name in built:
                sys.exit(f"ERROR: duplicate Dockerfiles for image {service_name!r}: "
                         f"second one at {dockerfile_path} (whichever builds last "
                         "would silently win the tag)")

            print(f"--- Found Dockerfile at: {dockerfile_path}")
            print(f"--- Service Name: {service_name}")
            print(f"--- Context Dir: {context_dir}")

            print(f"create Docker buildx builder for {service_name}")
            create_buildx_builder_if_not_exists(args.container_engine)
            print(f"building image for {service_name}")
            build_and_push_image(args, service_name, context_dir, dockerfile_path, image_tag)
            built.add(service_name)

    # A requested image with no matching Dockerfile is an error: silently
    # skipping it leaves stale or missing images in the registry and the
    # failure only surfaces much later as ImagePullBackOff.
    if args.images:
        missing = set(args.images) - built
        if missing:
            sys.exit(f"ERROR: no Dockerfile found for requested image(s): {sorted(missing)} "
                     "(is the directory committed?)")


def make_parser():
    """Create the argument parser for push-images.

    Exported as a module-level function so tests (push_images_test.py) can
    exercise the real parser rather than re-creating a parallel copy that
    might drift from the production definition.
    """
    parser = argparse.ArgumentParser(description="Build and push Docker images")
    parser.add_argument("--image-prefix",
                        dest="image_prefix",
                        help="Prefix for the image name. requires slash at the end if a path",
                        type=str,
                        default=os.getenv("IMAGE_PREFIX"))
    parser.add_argument("--extra-image-tag",
                        dest="extra_image_tags",
                        help="Additional tags to use when publishing images.",
                        type=str,
                        action="append",
                        default=[])
    parser.add_argument("--kind-cluster-name",
                        dest="kind_cluster_name",
                        help="Name of the kind cluster. If set, images will be loaded into the cluster",
                        type=str,
                        default=os.getenv("KIND_CLUSTER_NAME"))
    parser.add_argument("--controller-only",
                        dest="controller_only",
                        action="store_true",
                        help="Only build and push the agent-sandbox-controller image.")
    parser.add_argument("--image-tag",
                        dest="image_tag",
                        help="Image tag for this build. If not set, a default tag is generated based on date and git commit",
                        type=str,
                        default=os.getenv("IMAGE_TAG"))
    parser.add_argument("--images",
                        dest="images",
                        help="List of images to build and push. If not set, all images will be built and pushed",
                        nargs="+",
                        default=[])
    parser.add_argument("--container-engine",
                        dest="container_engine",
                        help="Container engine to use (docker or podman). "
                             "Also read from the CONTAINER_ENGINE env var.",
                        type=str,
                        choices=["docker", "podman"],
                        default=os.getenv("CONTAINER_ENGINE", "docker"))
    return parser


if __name__ == "__main__":
    parser = make_parser()
    args = parser.parse_args()

    # argparse choices only validates CLI-supplied values, not defaults from
    # environment variables.  Explicitly validate the resolved value so a
    # typo in CONTAINER_ENGINE fails fast instead of silently falling through.
    if args.container_engine not in ("docker", "podman"):
        sys.exit(f"ERROR: unsupported container engine {args.container_engine!r} "
                 "(choose docker or podman, or unset CONTAINER_ENGINE)")

    if args.kind_cluster_name:
        args.docker_build_output_type = "docker"
    else:
        args.docker_build_output_type = "registry"

    main(args)
