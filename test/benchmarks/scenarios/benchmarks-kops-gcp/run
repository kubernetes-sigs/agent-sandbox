# run: all-in-one benchmark entrypoint (create -> run tests -> teardown).
#
# This is a thin, backward-compatible orchestrator over the modular phase
# scripts (create-cluster / run-tests / teardown), preserving the behavior the
# external CI (Prow) job expects: it provisions an ephemeral kOps cluster,
# runs the e2e benchmarks and the stress test, and always tears the cluster
# down on exit.
#
# For iterating on a persistent cluster or running tests selectively, use the
# phase scripts directly instead of this wrapper.

set -o errexit
set -o nounset
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

CONFIG_REF="default"
# The cluster name lives in the config manifest; all three phases share it.
# Concurrent CI runs stay isolated because Boskos leases a distinct project
# (hence a distinct state store) per run.
CLUSTER_NAME="$(cluster_name_from_manifest "$(resolve_config "${CONFIG_REF}")")"

# Always tear down, however we exit (success, failure, or interrupt). CLEANUP_BUCKET
# defaults to false so parallel runs can share the state-store bucket.
cleanup() {
  echo "[run] Cleaning up..."
  local args=(--cluster-name "${CLUSTER_NAME}")
  if [[ "${CLEANUP_BUCKET:-false}" == "true" ]]; then
    args+=(--cleanup-bucket)
  fi
  "${SCRIPT_DIR}/teardown" "${args[@]}" || true
  echo "[run] DONE"
}
trap cleanup EXIT

"${SCRIPT_DIR}/create-cluster" --config "${CONFIG_REF}"

"${SCRIPT_DIR}/run-tests" \
  --cluster-name "${CLUSTER_NAME}" \
  --tests benchmarks,stress \
  --sandbox-count 200 \
  --create-concurrency 50

echo "[run] Benchmark run completed successfully."
