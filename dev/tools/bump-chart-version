"""Bumps the helm/Chart.yaml patch version if any generated helm files changed."""

import re
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
CHART_FILE = REPO_ROOT / "helm" / "Chart.yaml"

GENERATED_PATHS = [
    "helm/crds/",
    "helm/templates/rbac.generated.yaml",
    "helm/templates/extensions-rbac.generated.yaml",
]


def generated_files_changed():
    result = subprocess.run(
        ["git", "diff", "--name-only", "HEAD", "--"] + GENERATED_PATHS,
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
    )
    # Also check untracked/unstaged changes
    result2 = subprocess.run(
        ["git", "diff", "--name-only", "--"] + GENERATED_PATHS,
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
    )
    changed = set(result.stdout.splitlines()) | set(result2.stdout.splitlines())
    return bool(changed)


def bump_patch_version():
    text = CHART_FILE.read_text()
    match = re.search(r"^version:\s*(\d+)\.(\d+)\.(\d+)", text, re.MULTILINE)
    if not match:
        print("ERROR: could not find version in Chart.yaml", file=sys.stderr)
        sys.exit(1)
    major, minor, patch = int(match.group(1)), int(match.group(2)), int(match.group(3))
    old = f"{major}.{minor}.{patch}"
    new = f"{major}.{minor}.{patch + 1}"
    CHART_FILE.write_text(text.replace(f"version: {old}", f"version: {new}", 1))
    print(f"Bumped chart version: {old} -> {new}")


if __name__ == "__main__":
    if generated_files_changed():
        bump_patch_version()
    else:
        print("No generated files changed; chart version unchanged.")
