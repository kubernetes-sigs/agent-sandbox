# benchmark-kops-gcp runs benchmarks against a kOps cluster on GCP.

set -o errexit
set -o nounset
set -o pipefail

# Start in the root of the repository.
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

export WORKDIR="${REPO_ROOT}/.build"
rm -rf "${WORKDIR}"
mkdir -p "${WORKDIR}/bin"

export BINDIR="${WORKDIR}/bin"
export PATH="${BINDIR}:${PATH}"

export KUBECONFIG="${WORKDIR}/kubeconfig"

# Install kOps to bin dir
echo "Installing kOps to ${BINDIR}..."
GOBIN="${BINDIR}" go install k8s.io/kops/cmd/kops@v1.36.0-beta.1

# Install resourcectl to bin dir
echo "Installing resourcectl to ${BINDIR}..."
pushd dev/tools
GOBIN="${BINDIR}" go install ./resourcectl
popd

UNIQUE_SUFFIX="$(date +%Y%m%d-%H%M%S)"

# Get project info from boskos if available, otherwise use the default project.
if [[ -n "${BOSKOS_HOST:-}" ]]; then
  if ! PROJECT_ID=$(resourcectl get --key project-main --boskos-type gce-project); then
    echo "Failed to acquire project from Boskos"
    exit 1
  fi
  echo "Acquired project ${PROJECT_ID} from Boskos."
else
  PROJECT_ID=$(gcloud config get-value project)
fi

PROJECT_NUMBER=$(gcloud projects describe "${PROJECT_ID}" --format="value(projectNumber)")
echo "Using project: ${PROJECT_ID} (number: ${PROJECT_NUMBER})"

IMAGE_PREFIX="gcr.io/${PROJECT_ID}/agent-sandbox/"
export IMAGE_PREFIX
echo "Using image prefix: ${IMAGE_PREFIX}"

# Configure Docker to use gcloud credential helper for gcr.io
gcloud auth configure-docker --quiet gcr.io

# We don't set up registry permissions here because Boskos does not allow
# configuring IAM permissions on the project. The kOps cluster is configured
# to use the default compute service account, which has access by default.

# Compute image tag based on the git tag
IMAGE_TAG=$(git describe --tags --dirty --always)
# Add a timestamp if it's dirty
if [[ "${IMAGE_TAG}" == *"-dirty" ]]; then
  IMAGE_TAG="${IMAGE_TAG}-${UNIQUE_SUFFIX}"
fi
export IMAGE_TAG
echo "Using image tag: ${IMAGE_TAG}"

# Push images
for image in "agent-sandbox-controller" "chrome-sandbox" "bpftrace"; do
  echo "Pushing ${image} to ${IMAGE_PREFIX}..."
  dev/tools/push-images --image-prefix="${IMAGE_PREFIX}" --images "${image}"
done


BUCKET_NAME="kops-state-${PROJECT_NUMBER}"
echo "Using bucket: ${BUCKET_NAME}"

# Create state store bucket if not exists
if ! gcloud storage buckets describe "gs://${BUCKET_NAME}" >/dev/null 2>&1; then
  echo "Creating bucket gs://${BUCKET_NAME}..."
  gcloud storage buckets create "gs://${BUCKET_NAME}" --project="${PROJECT_ID}" --location=us-central1
else
  echo "Bucket gs://${BUCKET_NAME} already exists."
fi

export KOPS_STATE_STORE="gs://${BUCKET_NAME}"

# Compute a relatively unique identifier for this run to allow concurrent runs
CLUSTER_NAME="sandbox-${UNIQUE_SUFFIX}"
ZONE="us-central1-a"

cleanup() {
  echo "Cleaning up..."

  kops delete cluster --name="${CLUSTER_NAME}" --yes || true
  # By default we don't delete the bucket, so that we can run parallel tests.
  if [[ "${CLEANUP_BUCKET:-false}" == "true" ]]; then
    echo "Deleting bucket gs://${BUCKET_NAME}..."
    gcloud storage buckets delete "gs://${BUCKET_NAME}" --quiet || true
  fi

  echo "Cleaning up resources via resourcectl..."
  resourcectl cleanup || true

  rm -rf "${WORKDIR}"
  echo "DONE"
}

trap cleanup EXIT

# Cluster size is overridable so the same script can drive large-scale runs.
# The default (10 x n2-standard-8, ~110 pods/node) gives roughly 1100 pod slots.
# Node-side pod startup (~2 sandboxes/s per node) is the throughput bottleneck,
# so sandbox launch throughput scales with worker count.
# For a ~10k pod stress run, use something like NODE_COUNT=100 and a larger
# control plane (e.g. CONTROL_PLANE_SIZE=n2-standard-16), and scale the
# STRESS_* variables below to match.
NODE_COUNT="${NODE_COUNT:-20}"
NODE_SIZE="${NODE_SIZE:-n2-standard-8}"
CONTROL_PLANE_SIZE="${CONTROL_PLANE_SIZE:-n2-standard-8}"

echo "Creating kOps cluster configuration..."
# --gce-service-account=default: needed because boskos doesn't let us configure IAM permissions on the project.
#
# authorizationAlwaysAllowPaths: allow unauthenticated GETs of /metrics on
# kube-controller-manager and kube-scheduler so the stress test can scrape
# them through the apiserver pod proxy (the apiserver strips the
# Authorization header after authenticating, so the proxied request is
# anonymous and the default delegated authorization rejects it with 403).
# The health probe paths must be repeated because setting the field replaces
# the upstream default, and kOps liveness probes hit /healthz.
# Ports 10257/10259 are not internet-reachable: kOps GCE creates a
# deny-by-default VPC and only control-plane instances can reach them.
kops create cluster \
  --cloud=gce \
  --gce-service-account=default \
  --name="${CLUSTER_NAME}" \
  --zones="${ZONE}" \
  --project="${PROJECT_ID}" \
  --control-plane-count=1 \
  --control-plane-size="${CONTROL_PLANE_SIZE}" \
  --node-count="${NODE_COUNT}" \
  --node-size="${NODE_SIZE}" \
  --set cluster.spec.kubeControllerManager.authorizationAlwaysAllowPaths=/healthz \
  --set cluster.spec.kubeControllerManager.authorizationAlwaysAllowPaths=/readyz \
  --set cluster.spec.kubeControllerManager.authorizationAlwaysAllowPaths=/livez \
  --set cluster.spec.kubeControllerManager.authorizationAlwaysAllowPaths=/metrics \
  --set cluster.spec.kubeScheduler.authorizationAlwaysAllowPaths=/healthz \
  --set cluster.spec.kubeScheduler.authorizationAlwaysAllowPaths=/readyz \
  --set cluster.spec.kubeScheduler.authorizationAlwaysAllowPaths=/livez \
  --set cluster.spec.kubeScheduler.authorizationAlwaysAllowPaths=/metrics

echo "Applying cluster configuration..."
kops update cluster --name "${CLUSTER_NAME}" --yes

echo "Exporting kubeconfig..."
kops export kubeconfig --name "${CLUSTER_NAME}" --admin

echo "Waiting for cluster to be ready..."
kops validate cluster --wait 10m


# Deploy to cluster
echo "Deploying to cluster..."
dev/tools/deploy-to-kube --image-prefix="${IMAGE_PREFIX}" --extensions

# Wait for controller to be ready
echo "Waiting for controller to be ready..."
kubectl rollout status deployment agent-sandbox-controller --namespace agent-sandbox-system --timeout=10m

# Run the benchmarks
echo "Running benchmarks..."
dev/tools/test-e2e --suite=benchmarks --image-prefix="${IMAGE_PREFIX}"
echo "Benchmark completed successfully."


# Run the stress test.
#
# The stress test runs three phases (see test/stress/main.go):
#   fill:       long-running background sandboxes, so we measure a cluster at scale
#   probe:      low-concurrency launches measuring clean per-sandbox launch latency
#   throughput: closed-loop churn (create -> ready -> delete) capped at max-in-flight,
#               measuring sustained launches/sec without queueing on cluster capacity
#
# Keep fill-count + max-in-flight below the cluster's spare pod capacity
# (roughly NODE_COUNT * 110 minus system pods); the test warns if they don't fit.
# Defaults below are sized for the default 10-node cluster: enough in-flight
# pods per node to saturate node-side pod startup, while staying well below
# capacity. For a ~10k pod run:
#   NODE_COUNT=100 STRESS_FILL_COUNT=10000 STRESS_MAX_IN_FLIGHT=500 \
#   STRESS_CREATE_CONCURRENCY=100 STRESS_TIMEOUT=2h
STRESS_OUTPUT_DIR="${ARTIFACTS:-.}/stress-test/"
mkdir -p "${STRESS_OUTPUT_DIR}"

# Deploy the node profiler (bpftrace fsync tracing + containerd event stream)
# so node-side pod startup/teardown costs are captured during the stress test.
# See test/stress/profiler/profiler.yaml for what is recorded and why.
STRESS_NODE_PROFILER="${STRESS_NODE_PROFILER:-true}"
if [[ "${STRESS_NODE_PROFILER}" == "true" ]]; then
  echo "Deploying node profiler..."
  # bpftrace:latest → ${IMAGE_PREFIX}bpftrace:${IMAGE_TAG} (images/bpftrace).
  sed "s|image: bpftrace:latest|image: ${IMAGE_PREFIX}bpftrace:${IMAGE_TAG}|g" \
    test/stress/profiler/profiler.yaml | kubectl apply -f -
  # Best-effort: a missing image or unsupported kernel should not fail the run.
  kubectl rollout status daemonset/stress-node-profiler --namespace stress-node-profiler --timeout=2m || true
fi

# Prometheus metrics from the apiserver, kube-controller-manager,
# kube-scheduler, the sandbox controller, and kubelets are collected by the
# stress tool itself (metrics.jsonl.gz; see --collect-metrics).

echo "Running stress test"
go run ./test/stress \
  --fill-count="${STRESS_FILL_COUNT:-150}" \
  --probe-count="${STRESS_PROBE_COUNT:-30}" \
  --throughput-count="${STRESS_THROUGHPUT_COUNT:-1000}" \
  --max-in-flight="${STRESS_MAX_IN_FLIGHT:-200,100,50}" \
  --create-concurrency="${STRESS_CREATE_CONCURRENCY:-50}" \
  --timeout="${STRESS_TIMEOUT:-30m}" \
  --output-dir="${STRESS_OUTPUT_DIR}"
echo "Stress test completed successfully."

# Harvest per-node profiler logs into the artifacts directory.
if [[ "${STRESS_NODE_PROFILER}" == "true" ]]; then
  echo "Harvesting node profiler logs..."
  kubectl get pods --namespace stress-node-profiler \
    -o jsonpath='{range .items[*]}{.metadata.name} {.spec.nodeName}{"\n"}{end}' | \
  while read -r pod node; do
    kubectl logs --namespace stress-node-profiler "${pod}" -c fsync-trace > "${STRESS_OUTPUT_DIR}/profiler-fsync-${node}.log" || true
    kubectl logs --namespace stress-node-profiler "${pod}" -c ctr-events > "${STRESS_OUTPUT_DIR}/profiler-ctr-events-${node}.log" || true
  done
  kubectl delete -f test/stress/profiler/profiler.yaml --wait=false || true
fi

# Capture controller diagnostics alongside the stress test results.
echo "Capturing controller diagnostics..."
kubectl logs deployment/agent-sandbox-controller --namespace agent-sandbox-system --tail=-1 > "${STRESS_OUTPUT_DIR}/controller.log" || true
kubectl get pods -A -o wide > "${STRESS_OUTPUT_DIR}/pods.txt" || true
kubectl get nodes -o wide > "${STRESS_OUTPUT_DIR}/nodes.txt" || true
kubectl top nodes > "${STRESS_OUTPUT_DIR}/top-nodes.txt" 2>/dev/null || true
