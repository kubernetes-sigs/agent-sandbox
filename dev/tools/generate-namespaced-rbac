"""Generate Helm NOTES RBAC fragments from controller-gen output."""

import os
import sys

import yaml

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
REPO_ROOT = os.path.abspath(os.path.join(SCRIPT_DIR, "..", ".."))
sys.path.insert(0, os.path.join(SCRIPT_DIR, "shared"))

from rbac_notes import watched_namespace_rules


GENERATED_HEADER = "# Code generated by dev/tools/generate-namespaced-rbac. DO NOT EDIT.\n"
GENERATED_FILES = (
    ("rbac.generated.yaml", "rbac.namespaced.generated.yaml"),
    ("extensions-rbac.generated.yaml", "extensions-rbac.namespaced.generated.yaml"),
)


def generate(source_name, destination_name):
    source_path = os.path.join(REPO_ROOT, "helm", "files", source_name)
    destination_path = os.path.join(REPO_ROOT, "helm", "files", destination_name)

    with open(source_path, encoding="utf-8") as source:
        cluster_role = yaml.safe_load(source)

    rules = watched_namespace_rules(cluster_role)
    rendered = GENERATED_HEADER + yaml.safe_dump(
        rules,
        default_flow_style=False,
        sort_keys=False,
    )
    with open(destination_path, "w", encoding="utf-8") as destination:
        destination.write(rendered)


def main():
    for source_name, destination_name in GENERATED_FILES:
        generate(source_name, destination_name)


if __name__ == "__main__":
    main()
