# stress-duckdb: register stress-test runs into a local DuckDB database and
# explore them in the DuckDB web UI (runs in docker, no local installs).
#
#   stress-duckdb register <run>...   download artifacts + rebuild the database
#   stress-duckdb ui                  launch the web UI (http://localhost:4213)
#   stress-duckdb ui-stop             stop the web UI container
#   stress-duckdb sql "SELECT ..."    run a one-off query
#
# <run> may be a gcsweb URL, a storage.googleapis.com URL, a gs:// URL
# (pointing at the prow build or its artifacts/stress-test dir), or a local
# artifacts directory. Runs accumulate in ${STRESS_DUCKDB_HOME}; re-registering
# a run refreshes it.
#
# Tables: runs_raw (summary.json verbatim), sandboxes, timeseries, metrics.
# Canned queries are shipped as views (visible in the UI catalog): v_runs,
# phases, v_launch_latency, v_deletion, v_gc_queue_depth, v_workqueue_depth,
# v_metric_rate. Your own queries can be saved as notebooks in the UI (state
# persists under ${STRESS_DUCKDB_HOME}/.duckdb).

set -o errexit
set -o nounset
set -o pipefail

DATA_DIR="${STRESS_DUCKDB_HOME:-${HOME}/.cache/agent-sandbox-stress}"
DB="${DATA_DIR}/stress.duckdb"
IMAGE="${STRESS_DUCKDB_IMAGE:-duckdb/duckdb:latest}"
UI_CONTAINER="stress-duckdb-ui"
UI_PORT="${STRESS_DUCKDB_PORT:-4213}"

mkdir -p "${DATA_DIR}/runs" "${DATA_DIR}/.duckdb"

# Artifacts we ingest; watch.jsonl(.gz) and profiler logs are analyzed by
# dedicated tools and stay out of the database for now.
FILES=(summary.json sandboxes.jsonl timeseries.jsonl metrics.jsonl.gz)

duckdb_run() { # duckdb_run <docker-flags...> -- <duckdb-args...>
  local dockerflags=()
  while [[ "$1" != "--" ]]; do dockerflags+=("$1"); shift; done
  shift
  docker run --rm "${dockerflags[@]}" \
    -v "${DATA_DIR}:/data" \
    -v "${DATA_DIR}/.duckdb:/root/.duckdb" \
    "${IMAGE}" /duckdb "$@"
}

normalize_url() { # gcsweb / gs:// / https -> https://storage.googleapis.com/... of the stress-test dir
  local url="$1"
  url="${url%/}"
  url="${url/https:\/\/gcsweb.k8s.io\/gcs\//https://storage.googleapis.com/}"
  url="${url/gs:\/\//https://storage.googleapis.com/}"
  if [[ "${url}" != *"/artifacts/stress-test" ]]; then
    url="${url}/artifacts/stress-test"
  fi
  echo "${url}"
}

register_one() {
  local src="$1" run_id dir
  if [[ -d "${src}" ]]; then
    run_id="$(basename "$(cd "${src}" && pwd)")"
    dir="${DATA_DIR}/runs/${run_id}"
    mkdir -p "${dir}"
    for f in "${FILES[@]}"; do
      [[ -f "${src}/${f}" ]] && cp "${src}/${f}" "${dir}/" || true
    done
  else
    local url
    url="$(normalize_url "${src}")"
    # run id = prow build id = path component before /artifacts
    run_id="$(echo "${url}" | sed -n 's|.*/\([^/]*\)/artifacts/stress-test$|\1|p')"
    if [[ -z "${run_id}" ]]; then
      echo "cannot determine run id from ${src}" >&2
      return 1
    fi
    dir="${DATA_DIR}/runs/${run_id}"
    mkdir -p "${dir}"
    for f in "${FILES[@]}"; do
      if ! curl -fsS -o "${dir}/${f}" "${url}/${f}"; then
        echo "  (no ${f})"
        rm -f "${dir}/${f}"
      fi
    done
  fi
  if [[ ! -f "${dir}/summary.json" ]]; then
    echo "run ${run_id}: no summary.json found, not registering" >&2
    rm -rf "${dir}"
    return 1
  fi
  echo "registered run ${run_id} in ${dir}"
}

rebuild_db() {
  local sql="${DATA_DIR}/build.sql"
  {
    echo "CREATE OR REPLACE TABLE runs_raw AS
      SELECT regexp_extract(filename, 'runs/([^/]+)/', 1) AS run_id, *
      FROM read_json_auto('/data/runs/*/summary.json', filename=true, union_by_name=true);"

    # Optional tables: only reference globs that match something.
    if compgen -G "${DATA_DIR}/runs/*/sandboxes.jsonl" > /dev/null; then
      echo "CREATE OR REPLACE TABLE sandboxes AS
        SELECT regexp_extract(filename, 'runs/([^/]+)/', 1) AS run_id, *
        FROM read_json_auto('/data/runs/*/sandboxes.jsonl', filename=true, union_by_name=true);"
    fi
    if compgen -G "${DATA_DIR}/runs/*/timeseries.jsonl" > /dev/null; then
      echo "CREATE OR REPLACE TABLE timeseries AS
        SELECT regexp_extract(filename, 'runs/([^/]+)/', 1) AS run_id, *
        FROM read_json_auto('/data/runs/*/timeseries.jsonl', filename=true, union_by_name=true);"
    fi
    if compgen -G "${DATA_DIR}/runs/*/metrics.jsonl.gz" > /dev/null; then
      echo "CREATE OR REPLACE TABLE metrics AS
        SELECT regexp_extract(filename, 'runs/([^/]+)/', 1) AS run_id, * EXCLUDE (filename)
        FROM read_json_auto('/data/runs/*/metrics.jsonl.gz', filename=true, union_by_name=true);"
    fi

    cat <<'SQL'
-- Headline numbers per run: the trend table.
CREATE OR REPLACE VIEW v_runs AS
SELECT run_id,
       startTime::TIMESTAMPTZ AS run_ts,
       cluster.kubernetesVersion AS k8s,
       cluster.nodes AS worker_nodes,
       config.maxInFlight AS max_in_flight,
       phases.probe.latency.endToEndReady.p50Ms AS probe_e2e_p50_ms,
       phases.probe.latency.endToEndReady.p90Ms AS probe_e2e_p90_ms,
       phases.probe.latency.scheduledToPodRunning.p50Ms AS probe_sched_to_running_p50_ms,
       phases.throughput.readyThroughput.steadyStatePerSecond AS tp_ready_steady_per_s,
       phases.throughput.readyThroughputPerNode.steadyStatePerSecond AS tp_ready_steady_per_node_per_s,
       phases.throughput.latency.endToEndReady.p50Ms AS tp_e2e_p50_ms,
       phases.fill.durationSeconds AS fill_duration_s
FROM runs_raw ORDER BY run_ts;

-- Phase wall-clock windows (phases run sequentially from startTime).
CREATE OR REPLACE VIEW phases AS
WITH r AS (
  SELECT run_id, startTime::TIMESTAMPTZ AS t0,
         coalesce(phases.fill.durationSeconds, 0) AS d_fill,
         coalesce(phases.probe.durationSeconds, 0) AS d_probe,
         coalesce(phases.throughput.durationSeconds, 0) AS d_tp
  FROM runs_raw)
SELECT run_id, 'fill' AS phase, t0 AS start_ts, t0 + d_fill * INTERVAL 1 SECOND AS end_ts FROM r WHERE d_fill > 0
UNION ALL
SELECT run_id, 'probe', t0 + d_fill * INTERVAL 1 SECOND, t0 + (d_fill + d_probe) * INTERVAL 1 SECOND FROM r WHERE d_probe > 0
UNION ALL
SELECT run_id, 'throughput', t0 + (d_fill + d_probe) * INTERVAL 1 SECOND, t0 + (d_fill + d_probe + d_tp) * INTERVAL 1 SECOND FROM r WHERE d_tp > 0;

-- Launch latency per run/phase from per-sandbox records.
CREATE OR REPLACE VIEW v_launch_latency AS
SELECT run_id, phase, count(*) AS n,
       round(quantile_cont(sandboxReadyMs, 0.50), 0) AS e2e_p50_ms,
       round(quantile_cont(sandboxReadyMs, 0.90), 0) AS e2e_p90_ms,
       round(quantile_cont(sandboxReadyMs, 0.99), 0) AS e2e_p99_ms
FROM sandboxes WHERE sandboxReadyMs IS NOT NULL
GROUP BY 1, 2 ORDER BY run_id, phase;

-- Deletion cost per run/phase (delete call -> pod observed gone).
CREATE OR REPLACE VIEW v_deletion AS
SELECT run_id, phase, count(*) AS n,
       round(quantile_cont(epoch(podDeleted::TIMESTAMPTZ - deleteCalled::TIMESTAMPTZ), 0.50), 2) AS delete_to_gone_p50_s,
       round(quantile_cont(epoch(podDeleted::TIMESTAMPTZ - deleteCalled::TIMESTAMPTZ), 0.90), 2) AS delete_to_gone_p90_s
FROM sandboxes WHERE podDeleted IS NOT NULL AND deleteCalled IS NOT NULL
GROUP BY 1, 2 ORDER BY run_id, phase;

-- The KCM garbage collector queue: the suspected churn-throughput ceiling.
CREATE OR REPLACE VIEW v_gc_queue_depth AS
SELECT run_id, ts, instance, labels['name'] AS queue, value AS depth
FROM metrics
WHERE source = 'kube-controller-manager' AND metric = 'workqueue_depth'
  AND labels['name'] LIKE 'garbage_collector%'
ORDER BY run_id, ts;

-- All workqueue depths across components.
CREATE OR REPLACE VIEW v_workqueue_depth AS
SELECT run_id, ts, source, instance, labels['name'] AS queue, value AS depth
FROM metrics WHERE metric = 'workqueue_depth'
ORDER BY run_id, ts;

-- Generic counter -> rate/s: filter by metric before selecting from this view.
CREATE OR REPLACE VIEW v_metric_rate AS
SELECT run_id, source, instance, metric, labels, ts,
       (value - lag(value) OVER w) / greatest(epoch(ts::TIMESTAMPTZ - lag(ts::TIMESTAMPTZ) OVER w), 0.001) AS rate_per_s
FROM metrics
WINDOW w AS (PARTITION BY run_id, source, instance, metric, CAST(labels AS VARCHAR) ORDER BY ts);
SQL
  } > "${sql}"

  duckdb_run -i -- /data/stress.duckdb -c ".read /data/build.sql"
  duckdb_run -i -- /data/stress.duckdb -c "SELECT run_id, k8s, worker_nodes, tp_ready_steady_per_s FROM v_runs"
}

cmd="${1:-}"
shift || true
case "${cmd}" in
  register)
    [[ $# -ge 1 ]] || { echo "usage: stress-duckdb register <run-url-or-dir>..." >&2; exit 1; }
    for src in "$@"; do register_one "${src}"; done
    rebuild_db
    ;;
  ui)
    docker rm -f "${UI_CONTAINER}" >/dev/null 2>&1 || true
    docker run -dit --name "${UI_CONTAINER}" --network=host \
      -v "${DATA_DIR}:/data" \
      -v "${DATA_DIR}/.duckdb:/root/.duckdb" \
      "${IMAGE}" /duckdb /data/stress.duckdb \
      -cmd "SET ui_local_port=${UI_PORT}; CALL start_ui_server();" >/dev/null
    echo "DuckDB UI: http://localhost:${UI_PORT}  (notebooks persist in ${DATA_DIR}/.duckdb)"
    echo "stop with: $0 ui-stop"
    ;;
  ui-stop)
    docker rm -f "${UI_CONTAINER}" >/dev/null 2>&1 || true
    echo "stopped"
    ;;
  sql)
    duckdb_run -i -- /data/stress.duckdb -c "$*"
    ;;
  *)
    sed -n '17,34p' "$0"
    exit 1
    ;;
esac
