# Thin wrapper so callers can invoke stress-duckdb from the repo root:
#   ./dev/tools/run-stress-duckdb 1122
set -o errexit
set -o nounset
set -o pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "${REPO_ROOT}/dev/tools"
exec go run ./stress-duckdb "$@"
